{
  "openapi": "3.0.3",
  "info": {
    "title": "BarangaEco Mobile API",
    "version": "1.0.0",
    "description": "Swagger/OpenAPI specification for the mobile API routes defined in routes/api.php."
  },
  "servers": [
    {
      "url": "http://barangaeco.test/api",
      "description": "Laravel Herd local API"
    },
    {
      "url": "https://barangaeco.test/api",
      "description": "Laravel Herd local API over HTTPS"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication and authenticated user endpoints"
    },
    {
      "name": "Resident",
      "description": "Resident mobile endpoints"
    },
    {
      "name": "Collector",
      "description": "Collector mobile endpoints"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login",
        "description": "Authenticate a resident or collector and return a Sanctum bearer token.",
        "operationId": "authLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "resident@example.com",
                "password": "password",
                "device_name": "postman"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register resident",
        "description": "Register a new resident account and return a Sanctum bearer token.",
        "operationId": "authRegister",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/RegisterResidentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Resident registered successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Logout",
        "description": "Delete the authenticated user's current Sanctum token.",
        "operationId": "authLogout",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "message": "Logged out successfully."
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Current user",
        "description": "Return the authenticated user with resident or collector relationship data.",
        "operationId": "authMe",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated user.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/resident/dashboard": {
      "get": {
        "tags": [
          "Resident"
        ],
        "summary": "Resident dashboard",
        "description": "Return dashboard data for the authenticated resident.",
        "operationId": "residentDashboard",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Resident dashboard data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResidentDashboard"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/resident/document-requests": {
      "get": {
        "tags": [
          "Resident"
        ],
        "summary": "List document requests",
        "operationId": "residentDocumentRequestsIndex",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Page"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated resident document requests.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedDocumentRequests"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": [
          "Resident"
        ],
        "summary": "Create document request",
        "operationId": "residentDocumentRequestsStore",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StoreDocumentRequest"
              },
              "example": {
                "document_type": "Barangay Clearance",
                "purpose": "Employment",
                "reason": "Required for job application."
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document request created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentRequest"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/resident/document-requests/{document_request}": {
      "get": {
        "tags": [
          "Resident"
        ],
        "summary": "Show document request",
        "operationId": "residentDocumentRequestsShow",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DocumentRequestId"
          }
        ],
        "responses": {
          "200": {
            "description": "Resident document request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentRequest"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/resident/complaints": {
      "get": {
        "tags": [
          "Resident"
        ],
        "summary": "List complaints",
        "operationId": "residentComplaintsIndex",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Page"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated resident complaints.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedComplaints"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": [
          "Resident"
        ],
        "summary": "Create complaint",
        "operationId": "residentComplaintsStore",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StoreComplaintRequest"
              },
              "example": {
                "barangay_id": 1,
                "complaint_type": "Waste Collection",
                "complaint_against": "Collection Team",
                "description": "Missed waste collection on the scheduled day."
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Complaint created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Complaint"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/resident/complaints/{complaint}": {
      "get": {
        "tags": [
          "Resident"
        ],
        "summary": "Show complaint",
        "operationId": "residentComplaintsShow",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ComplaintId"
          }
        ],
        "responses": {
          "200": {
            "description": "Resident complaint.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Complaint"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/collector/dashboard": {
      "get": {
        "tags": [
          "Collector"
        ],
        "summary": "Collector dashboard",
        "operationId": "collectorDashboard",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Collector dashboard data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectorDashboard"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/collector/schedules": {
      "get": {
        "tags": [
          "Collector"
        ],
        "summary": "List assigned schedules",
        "operationId": "collectorSchedulesIndex",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Page"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated schedules assigned to the authenticated collector.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedSchedules"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/collector/schedules/{schedule}": {
      "get": {
        "tags": [
          "Collector"
        ],
        "summary": "Show assigned schedule",
        "operationId": "collectorSchedulesShow",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ScheduleId"
          }
        ],
        "responses": {
          "200": {
            "description": "Assigned waste collection schedule.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WasteCollectionSchedule"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/collector/schedules/{schedule}/status": {
      "post": {
        "tags": [
          "Collector"
        ],
        "summary": "Update schedule status",
        "description": "Create or update the authenticated collector's status update for an assigned schedule.",
        "operationId": "collectorSchedulesStatusStore",
        "security": [
          {
            "sanctumBearer": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ScheduleId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StoreCollectionStatusRequest"
              },
              "example": {
                "status": "in_progress",
                "notes": "Collection has started."
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Schedule status saved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionStatusUpdate"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sanctumBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Sanctum token"
      }
    },
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "DocumentRequestId": {
        "name": "document_request",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "ComplaintId": {
        "name": "complaint",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "ScheduleId": {
        "name": "schedule",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      }
    },
    "responses": {
      "Unauthenticated": {
        "description": "Unauthenticated.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MessageResponse"
            },
            "example": {
              "message": "Unauthenticated."
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MessageResponse"
            },
            "example": {
              "message": "This action is unauthorized."
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MessageResponse"
            },
            "example": {
              "message": "Not Found"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Validation error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password",
          "device_name"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          },
          "device_name": {
            "type": "string"
          }
        }
      },
      "RegisterResidentRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "password",
          "password_confirmation",
          "full_name",
          "address",
          "barangay_id",
          "contact_number",
          "id_image",
          "device_name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 8
          },
          "password_confirmation": {
            "type": "string",
            "format": "password",
            "minLength": 8
          },
          "full_name": {
            "type": "string",
            "maxLength": 255
          },
          "address": {
            "type": "string"
          },
          "barangay_id": {
            "type": "integer"
          },
          "contact_number": {
            "type": "string"
          },
          "id_image": {
            "type": "string",
            "format": "binary"
          },
          "device_name": {
            "type": "string"
          }
        }
      },
      "StoreDocumentRequest": {
        "type": "object",
        "required": [
          "document_type",
          "purpose",
          "reason"
        ],
        "properties": {
          "document_type": {
            "type": "string",
            "maxLength": 255
          },
          "purpose": {
            "type": "string",
            "maxLength": 255
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "StoreComplaintRequest": {
        "type": "object",
        "required": [
          "barangay_id",
          "complaint_type",
          "complaint_against",
          "description"
        ],
        "properties": {
          "barangay_id": {
            "type": "integer"
          },
          "complaint_type": {
            "type": "string",
            "maxLength": 255
          },
          "complaint_against": {
            "type": "string",
            "maxLength": 255
          },
          "description": {
            "type": "string"
          }
        }
      },
      "StoreCollectionStatusRequest": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed"
            ]
          },
          "notes": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "AuthTokenResponse": {
        "type": "object",
        "required": [
          "token",
          "user"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "resident",
              "collector"
            ]
          },
          "email_verified_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "resident": {
            "$ref": "#/components/schemas/Resident"
          },
          "collector": {
            "$ref": "#/components/schemas/Collector"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Resident": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "user_id": {
            "type": "integer"
          },
          "barangay_id": {
            "type": "integer"
          },
          "full_name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "contact_number": {
            "type": "string"
          },
          "photo": {
            "type": "string",
            "nullable": true
          },
          "id_image": {
            "type": "string",
            "nullable": true
          },
          "verification_status": {
            "type": "string",
            "enum": [
              "pending",
              "verified",
              "rejected"
            ]
          },
          "verified_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "verified_by": {
            "type": "integer",
            "nullable": true
          },
          "barangay": {
            "$ref": "#/components/schemas/Barangay"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Collector": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "user_id": {
            "type": "integer"
          },
          "full_name": {
            "type": "string"
          },
          "contact_number": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Barangay": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Announcement": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "created_by": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "target_audience": {
            "type": "string",
            "enum": [
              "all",
              "residents",
              "collectors"
            ]
          },
          "scheduled_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "published_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DocumentRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "resident_id": {
            "type": "integer"
          },
          "document_type": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
